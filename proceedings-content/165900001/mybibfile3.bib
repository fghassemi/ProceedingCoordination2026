@InProceedings{Abdulla,
author="Abdulla, Parosh Aziz
and Deneux, Johann
and Ouaknine, Jo{\"e}l
and Worrell, James",
editor="Caires, Lu{\'i}s
and Italiano, Giuseppe F.
and Monteiro, Lu{\'i}s
and Palamidessi, Catuscia
and Yung, Moti",
title="Decidability and Complexity Results for Timed Automata via Channel Machines",
booktitle="Automata, Languages and Programming",
year="2005",
publisher="Springer",
address="Berlin, Heidelberg",
pages="1089--1101",
abstract="This paper is concerned with the language inclusion problem for timed automata: given timed automata {\$}{\{}{\backslash}mathcal A{\}}{\$}and {\$}{\{}{\backslash}mathcal B{\}}{\$}, is every word accepted by {\$}{\{}{\backslash}mathcal B{\}}{\$}also accepted by {\$}{\{}{\backslash}mathcal A{\}}{\$}? Alur and Dill [3] showed that the language inclusion problem is decidable if {\$}{\{}{\backslash}mathcal A{\}}{\$}has no clocks and undecidable if {\$}{\{}{\backslash}mathcal A{\}}{\$}has two clocks (with no restriction on {\$}{\{}{\backslash}mathcal B{\}}{\$}). However, the status of the problem when {\$}{\{}{\backslash}mathcal A{\}}{\$}has one clock is not determined by [3]. In this paper we close this gap for timed automata over infinite words by showing that the one-clock language inclusion problem is undecidable. For timed automata over finite words, building on our earlier paper [20], we show that the one-clock language inclusion problem is decidable with non-primitive recursive complexity. This reveals a surprising divergence between the theory of timed automata over finite words and over infinite words. Finally, we show that if $\epsilon$-transitions or non-singular postconditions are allowed, then the one-clock language inclusion problem is undecidable over both finite and infinite words.",
isbn="978-3-540-31691-6"
}




@InProceedings{Baier,
author="Baier, Christel
and Bertrand, Nathalie
and Bouyer, Patricia
and Brihaye, Thomas",
editor="Albers, Susanne
and Marchetti-Spaccamela, Alberto
and Matias, Yossi
and Nikoletseas, Sotiris
and Thomas, Wolfgang",
title="When Are Timed Automata Determinizable?",
booktitle="Automata, Languages and Programming",
year="2009",
publisher="Springer",
address="Berlin, Heidelberg",
pages="43--54",
abstract="In this paper, we propose an abstract procedure which, given a timed automaton, produces a language-equivalent deterministic infinite timed tree. We prove that under a certain boundedness condition, the infinite timed tree can be reduced into a classical deterministic timed automaton. The boundedness condition is satisfied by several subclasses of timed automata, some of them were known to be determinizable (event-clock timed automata, automata with integer resets), but some others were not. We prove for instance that strongly non-Zeno timed automata can be determinized. As a corollary of those constructions, we get for those classes the decidability of the universality and of the inclusion problems, and compute their complexities (the inclusion problem is for instance EXPSPACE-complete for strongly non-Zeno timed automata).",
isbn="978-3-642-02930-1"
}

