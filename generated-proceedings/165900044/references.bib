@article{saoud-assume-guarantee-2021,
	title = {Assume-guarantee contracts for continuous-time systems},
	volume = {134},
	issn = {0005-1098},
	url = {https://www.sciencedirect.com/science/article/pii/S0005109821004337},
	doi = {10.1016/j.automatica.2021.109910},
	abstract = {Many techniques for verifying properties of continuous-time systems are limited to systems of moderate size. In this paper, we propose an approach based on assume-guarantee contracts and compositional reasoning for verifying properties of a broad class of continuous-time systems consisting of interconnected components. The notion of assume-guarantee contracts makes it possible to divide responsibilities among the system components: a contract specifies the property that a component must fulfill under some assumptions on the behavior of its environment (i.e. of the other components). We define weak and strong semantics of assume-guarantee contracts. We then establish a certain number of results for compositional reasoning, which allow us to show that a global assume-guarantee contract of the whole system is satisfied when all components satisfy their own contracts. We show that the weak satisfaction of the contract is sufficient to deal with interconnections described by a directed acyclic graph, while strong satisfaction is needed to reason about general interconnections containing cycles. Specific results for systems described by differential inclusions and invariance assume-guarantee contracts are then developed. Finally, we show how the proposed assume-guarantee framework can recast different versions of the small-gain theorem as a particular case. Throughout the paper, the main results are illustrated using simple examples.},
	pages = {109910},
	journal = {Automatica},
	author = {Saoud, A. and Girard, A. and Fribourg, L.},
	urldate = {2024-07-15},
	date = {2021-12-01},
	year = 2021,
	month = dec,
	keywords = {Assume-guarantee contracts, Component-based design, Prefix-closed properties, Small-gain theorem},
	file = {ScienceDirect Snapshot:/home/scerf/Zotero/storage/QN7RV8KF/S0005109821004337.html:text/html;Version soumise:/home/scerf/Zotero/storage/GEZP5MQW/Saoud et al. - 2021 - Assume-guarantee contracts for continuous-time sys.pdf:application/pdf},
}

@article{prabhakar-simulations-2018,
	title = {Simulations and bisimulations for analysis of stability with respect to inputs of hybrid systems},
	volume = {28},
	issn = {1573-7594},
	url = {https://doi.org/10.1007/s10626-017-0262-9},
	doi = {10.1007/s10626-017-0262-9},
	abstract = {Simulation and bisimulation relations define pre-orders on processes which serve as the basis for approximation based verification techniques, and have been extended towards the design of continuous and hybrid systems with complex logic specifications. We study pre-orders between hybrid systems which preserve stability properties with respect to input. We show that these properties are not bisimulation invariant, and hence propose stronger notions which strengthen simulation and bisimulation relations with uniform continuity constraints. We show that uniform continuity is necessary on the relations corresponding to both the state-space and the input-space, and continuity itself does not suffice. Finally, we demonstrate the satisfiability of our definitions by casting the well-known Lyapunov function based techniques for stability analysis as constructing a simple one-dimensional system which is stable and uniformly continuously simulates the original system.},
	pages = {349--374},
	number = {3},
	journal = {Discrete Event Dynamic Systems},
	author = {Prabhakar, P. and Liu, J. and Murray, R. M.},
	urldate = {2024-07-15},
	date = {2018-09-01},
	year = 2018,
	month = sep,
	langid = {english},
	keywords = {Stability, Abstractions, Bisimulations, Hybrid systems, Incremental input-to-state stability, Input-to-state stability},
	file = {Full Text PDF:/home/scerf/Zotero/storage/VKSZDC7V/Prabhakar et al. - 2018 - Simulations and bisimulations for analysis of stab.pdf:application/pdf},
}

